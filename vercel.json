{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "cd frontend && npm ci && npm run build",
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@2.6.0",
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    }
  ]
}
