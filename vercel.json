{
  "buildCommand": "cd frontend && npm install && npm run build && cd ../api && npm install",
  "outputDirectory": "frontend/dist",
  "env": {
    "ALCHEMY_API_KEY": "@alchemy_api_key",
    "RELAYER_EVM_ADDRESS": "@relayer_evm_address",
    "RELAYER_EVM_PRIVATE_KEY": "@relayer_evm_private_key",
    "RELAYER_SOLANA_ADDRESS": "@relayer_solana_address",
    "RELAYER_SOLANA_PRIVATE_KEY": "@relayer_solana_private_key",
    "RELAYER_TRON_ADDRESS": "@relayer_tron_address",
    "RELAYER_TRON_PRIVATE_KEY": "@relayer_tron_private_key",
    "RELAYER_SUI_ADDRESS": "@relayer_sui_address",
    "RELAYER_SUI_PRIVATE_KEY": "@relayer_sui_private_key",
    "RECEIVING_ADDRESS_ETHEREUM": "@receiving_address_ethereum",
    "RECEIVING_ADDRESS_BSC": "@receiving_address_bsc",
    "RECEIVING_ADDRESS_POLYGON": "@receiving_address_polygon",
    "RECEIVING_ADDRESS_ARBITRUM": "@receiving_address_arbitrum",
    "RECEIVING_ADDRESS_BASE": "@receiving_address_base",
    "RECEIVING_ADDRESS_OPTIMISM": "@receiving_address_optimism",
    "RECEIVING_ADDRESS_AVALANCHE": "@receiving_address_avalanche",
    "RECEIVING_ADDRESS_SOLANA": "@receiving_address_solana",
    "RECEIVING_ADDRESS_TRON": "@receiving_address_tron",
    "RECEIVING_ADDRESS_SUI": "@receiving_address_sui",
    "CORS_ORIGIN": "@cors_origin",
    "PORT": "@port",
    "NODE_ENV": "@node_env"
  },
  "functions": {
    "api/**": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
